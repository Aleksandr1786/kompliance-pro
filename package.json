{
  "name": "kompliance-pro",
  "version": "1.0.41",
  "description": "КомплаенсПро — Аутсорс-платформа",
  "main": "main.js",
  "author": {
    "name": "ИП Свинцова Д.И.",
    "email": "kompliancepro@mail.ru"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.1.7",
    "lowdb": "1.0.0",
    "lvovich": "^2.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "ru.kompliance.pro",
    "productName": "КомплаенсПро",
    "copyright": "© 2026 ИП Свинцова Д.И.",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "language": "1049",
      "artifactName": "KomplainsPro-Setup.exe",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "КомплаенсПро",
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "preload.js",
      "generator.js",
      "gen_p1.js",
      "gen_p2.js",
      "gen_pd.js",
      "gen_vu.js",
      "gen_instructage.js",
      "gen_sout.js",
      "gen_chop.js",
      "gen_pasf.js",
      "doc-generation.js",
      "lock-utils.js",
      "ai-draft.js",
      "utils.js",
      "sections.js",
      "doc-meta.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Aleksandr1786",
      "repo": "kompliance-pro"
    }
  }
}
